generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  phone                  String?                 @unique
  email                  String?                 @unique
  username               String?                 @unique
  password               String?
  gender                 String?
  dob                    DateTime?
  role                   Role
  status                 UserStatus              @default(NEW)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  legacyId               String?                 @unique
  adminProfile           AdminProfile?
  buyerProfile           BuyerProfile?
  cart                   Cart?
  messages               Message[]
  notificationBroadcasts NotificationBroadcast[]
  notifications          Notification[]
  orders                 Order[]
  productRequests        ProductRequest[]
  productWaitlists       ProductWaitlist[]
  reviews                Review[]
  sellerProfile          SellerProfile?
  tickets                Ticket[]

  @@index([role])
  @@index([status])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model BuyerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  legalName          String
  gstNumber          String?
  panNumber          String?
  aadhaarNumber      String?
  drugLicenseNumber  String?
  drugLicenseUrl     String?
  city               String?
  state              String?
  pincode            String?
  latitude           Float?
  longitude          Float?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  bankAccount        Json?
  cancelCheck        String?
  creditTier         CreditTier?
  document           String?
  gstPanResponse     Json?
  inviteCode         String?
  referralCodeId     String?
  licence            Json?
  verificationStatus VerificationStatus @default(UNVERIFIED)
  address            Json?
  drugLicenseNumber2 String?
  drugLicenseUrl2    String?
  drugLicenseExpiry  DateTime?
  drugLicenseExpiry2 DateTime?
  referralCode       ReferralCode?      @relation("ReferredBuyers", fields: [referralCodeId], references: [id])
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  customOrders       CustomOrder[]
  referralCodes      ReferralCode[]     @relation("ReferrerCodes")

  @@index([city])
  @@index([state])
  @@index([pincode])
  @@index([verificationStatus])
  @@index([creditTier])
  @@map("buyer_profiles")
}

model SellerProfile {
  id                  String             @id @default(uuid())
  userId              String             @unique
  companyName         String
  gstNumber           String?
  panNumber           String?
  aadhaarNumber       String?
  drugLicenseNumber   String
  drugLicenseUrl      String
  address             String
  city                String
  state               String
  pincode             String
  isVacation          Boolean            @default(false)
  rating              Float              @default(0)
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  creditTier          CreditTier?
  gstPanResponse      Json?
  email               String?
  fssaiNumber         String?
  bankAccount         Json?
  cancelCheck         String?
  additionalDocuments String[]
  drugLicenseNumber2  String?
  drugLicenseUrl2     String?
  drugLicenseExpiry   DateTime?
  drugLicenseExpiry2  DateTime?
  orderItems          OrderItem[]
  sellerOffers        SellerOffer[]
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  settlements         SellerSettlement[]

  @@index([city])
  @@index([state])
  @@index([verificationStatus])
  @@index([creditTier])
  @@index([isVacation])
  @@map("seller_profiles")
}

model AdminProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  displayName String
  department  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  permissions String   @default("")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_profiles")
}

model Brand {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String
  isActive  Boolean  @default(true)
  order     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brands")
}

model Banner {
  id        String   @id @default(uuid())
  title     String?
  link      String?
  imageUrl  String
  isActive  Boolean  @default(true)
  order     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model Category {
  id                   String           @id @default(uuid())
  name                 String           @unique
  slug                 String           @unique
  image                String?
  createdAt            DateTime         @default(now())
  masterProducts       CatalogProduct[]
  sellerOffers         SellerOffer[]
  subCategories        SubCategory[]
  commissionPercent    Decimal?         @db.Decimal(10, 2)
  fixedFee             Decimal?         @db.Decimal(10, 2)
  commissionGstPercent Decimal?         @db.Decimal(10, 2)

  @@map("categories")
}

model SubCategory {
  id                   String           @id @default(uuid())
  name                 String
  slug                 String
  categoryId           String
  createdAt            DateTime         @default(now())
  masterProducts       CatalogProduct[]
  sellerOffers         SellerOffer[]
  commissionPercent    Decimal?         @db.Decimal(10, 2)
  fixedFee             Decimal?         @db.Decimal(10, 2)
  commissionGstPercent Decimal?         @db.Decimal(10, 2)
  category             Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  thirdCategories      ThirdCategory[]

  @@unique([slug, categoryId])
  @@index([categoryId])
  @@map("sub_categories")
}

model SellerOffer {
  id             String  @id @default(uuid())
  sellerId       String
  categoryId     String
  subCategoryId  String
  name           String
  manufacturer   String
  sku            String?
  serialNo       String?
  specifications String?

  description          String?
  mrp                  Decimal               @db.Decimal(10, 2)
  gstPercent           Decimal               @db.Decimal(10, 2)
  isTaxIncluded        Boolean               @default(false)
  shippingCharges      Decimal               @default(0) @db.Decimal(10, 2)
  finalShippingPrice   Decimal?              @db.Decimal(10, 2)
  finalCustomerPayable Decimal?              @db.Decimal(10, 2)
  minimumOrderQuantity Int                   @default(1)
  maximumOrderQuantity Int?
  isActive             Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  slug                 String?
  externalId           String?               @unique
  discountType         DiscountType?
  discountMeta         Json?
  deliveryText         String?
  approvalStatus       ProductApprovalStatus @default(PENDING)
  rejectionReason      String?
  variantId            String?
  productAnalyticsId   String?
  productSearchIndexId String?
  cartItems            CartItem[]
  inventoryAlerts      InventoryAlert[]
  marketingProducts    MarketingProduct[]
  orderItems           OrderItem[]
  batches              ProductBatch[]
  reviews              Review[]
  category             Category              @relation(fields: [categoryId], references: [id])
  analytics            ProductAnalytics?     @relation(fields: [productAnalyticsId], references: [id])
  searchIndex          ProductSearchIndex?   @relation(fields: [productSearchIndexId], references: [id])
  seller               SellerProfile         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  subCategory          SubCategory           @relation(fields: [subCategoryId], references: [id])
  variant              ProductVariant?       @relation(fields: [variantId], references: [id])
  catalogProductId     String?
  catalogProduct       CatalogProduct?       @relation(fields: [catalogProductId], references: [id])

  @@index([sellerId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([isActive])
  @@index([approvalStatus])
  @@index([name])
  @@index([manufacturer])
  @@index([deletedAt])
  @@index([externalId])
  @@index([name, manufacturer])
  @@index([categoryId, subCategoryId])
  @@index([slug])
  @@map("seller_offers")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id            String      @id @default(uuid())
  cartId        String
  sellerOfferId String
  quantity      Int
  unitPrice     Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cart          Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  sellerOffer   SellerOffer @relation(fields: [sellerOfferId], references: [id], onDelete: Cascade)

  @@unique([cartId, sellerOfferId])
  @@index([cartId])
  @@index([sellerOfferId])
  @@map("cart_items")
}

model Order {
  id                String        @id @default(uuid())
  buyerId           String
  totalAmount       Decimal       @db.Decimal(10, 2)
  orderStatus       OrderStatus   @default(PLACED)
  paymentStatus     PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  legacyId          String?       @unique
  referralCodeId    String?
  shiprocketOrderId String?
  shipmentId        String?
  awbCode           String?
  courierName       String?
  address           OrderAddress?
  items             OrderItem[]
  buyer             User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  referralCode      ReferralCode? @relation(fields: [referralCodeId], references: [id])
  payments          Payment[]

  // Shipping dimensions
  packageLength  Float?
  packageBreadth Float?
  packageHeight  Float?
  packageWeight  Float?

  // Dimension images
  lengthImage  String?
  breadthImage String?
  heightImage  String?
  weightImage  String?

  // Shipping documents
  invoiceUrl            String?
  manifestUrl           String?
  adminShippingLabelUrl String?
  adminInvoiceUrl       String?
  packedPictureUrl      String?

  // Shipping Lock
  isShippingLocked      Boolean @default(false)

  @@index([buyerId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id            String            @id @default(uuid())
  orderId       String
  sellerOfferId String
  sellerId      String
  quantity      Int
  unitPrice     Decimal           @db.Decimal(10, 2)
  totalPrice    Decimal           @db.Decimal(10, 2)
  createdAt     DateTime          @default(now())
  legacyId      String?           @unique
  order         Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seller        SellerProfile     @relation(fields: [sellerId], references: [id])
  sellerOffer   SellerOffer       @relation(fields: [sellerOfferId], references: [id])
  settlement    SellerSettlement?

  @@index([orderId])
  @@index([sellerOfferId])
  @@index([sellerId])
  @@map("order_items")
}

model Payment {
  id                 String                    @id @default(uuid())
  orderId            String
  amount             Decimal                   @db.Decimal(10, 2)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  legacyId           String?                   @unique
  method             PaymentMethod
  proofUrl           String?
  referenceNumber    String?
  verificationStatus PaymentVerificationStatus @default(PENDING)
  order              Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([verificationStatus])
  @@map("payments")
}

model Review {
  id               String         @id @default(uuid())
  userId           String
  catalogProductId String
  rating           Int
  comment          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sellerOfferId    String?
  catalogProduct   CatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)
  sellerOffer      SellerOffer?   @relation(fields: [sellerOfferId], references: [id])
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, catalogProductId])
  @@index([catalogProductId])
  @@index([rating])
  @@map("reviews")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationBroadcast {
  id             String   @id @default(uuid())
  adminId        String
  message        String
  target         String
  deliveredCount Int
  createdAt      DateTime @default(now())
  admin          User     @relation(fields: [adminId], references: [id])

  @@index([createdAt])
  @@map("notification_broadcasts")
}

model Ticket {
  id        String       @id @default(uuid())
  userId    String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  messages  Message[]
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

model Message {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String
  message   String
  createdAt DateTime @default(now())
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@map("messages")
}

model OrderAddress {
  id      String @id @default(uuid())
  orderId String @unique
  name    String
  phone   String
  address String
  city    String
  state   String
  pincode String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

model ProductBatch {
  id              String           @id @default(uuid())
  sellerOfferId   String
  batchNumber     String
  expiryDate      DateTime
  stock           Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  inventoryAlerts InventoryAlert[]
  sellerOffer     SellerOffer      @relation(fields: [sellerOfferId], references: [id], onDelete: Cascade)

  @@index([sellerOfferId])
  @@index([expiryDate])
  @@index([sellerOfferId, batchNumber])
  @@map("product_batches")
}

model ProductSearchIndex {
  id               String @id @default(uuid())
  catalogProductId String @unique
  name             String
  manufacturer     String

  categoryName    String
  subCategoryName String
  searchVector    String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  catalogProduct  CatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)
  sellerOffers    SellerOffer[]

  @@index([name])
  @@index([manufacturer])
  @@index([searchVector])
  @@index([categoryName])
  @@map("product_search_index")
}

model ProductAnalytics {
  id               String         @id @default(uuid())
  catalogProductId String         @unique
  views            Int            @default(0)
  orders           Int            @default(0)
  lastViewed       DateTime?
  lastOrdered      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  catalogProduct   CatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)
  sellerOffers     SellerOffer[]

  @@index([views])
  @@index([orders])
  @@index([lastViewed])
  @@map("product_analytics")
}

model InventoryAlert {
  id            String        @id @default(uuid())
  sellerOfferId String
  batchId       String?
  alertType     AlertType
  message       String
  createdAt     DateTime      @default(now())
  batch         ProductBatch? @relation(fields: [batchId], references: [id])
  sellerOffer   SellerOffer   @relation(fields: [sellerOfferId], references: [id], onDelete: Cascade)

  @@index([sellerOfferId])
  @@index([batchId])
  @@index([alertType])
  @@index([createdAt])
  @@map("inventory_alerts")
}

model SellerSettlement {
  id              String        @id @default(uuid())
  sellerId        String
  amount          Decimal       @db.Decimal(10, 2)
  grossAmount     Decimal       @db.Decimal(10, 2)
  commission      Decimal       @default(0) @db.Decimal(10, 2)
  commissionGst   Decimal       @db.Decimal(10, 2)
  fixedFee        Decimal       @db.Decimal(10, 2)
  fixedFeeGst     Decimal       @db.Decimal(10, 2)
  withholdingTax  Decimal       @db.Decimal(10, 2)
  netPayout       Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  orderItemId     String        @unique
  payoutDate      DateTime?
  payoutReference String?
  paymentProofUrl String?
  payoutStatus    String        @default("PENDING")
  updatedAt       DateTime      @updatedAt
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])
  seller          SellerProfile @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([payoutStatus])
  @@map("seller_settlements")
}

model BlogAuthor {
  id        String     @id @default(uuid())
  name      String
  bio       String?
  avatar    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posts     BlogPost[]

  @@map("blog_authors")
}

model BlogCategory {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posts     BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id              String        @id @default(uuid())
  title           String
  slug            String        @unique
  excerpt         String?
  content         Json
  featuredImage   String?
  images          String[]      @default([])
  authorId        String
  categoryId      String?
  tags            String[]      @default([])
  status          BlogStatus    @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]      @default([])
  canonicalUrl    String?
  ogImage         String?
  readingTime     Int           @default(0)
  views           Int           @default(0)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  author          BlogAuthor    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category        BlogCategory? @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([views])
  @@index([status, publishedAt])
  @@map("blog_posts")
}

model MigrationRun {
  id           String              @id @default(uuid())
  entityType   MigrationEntityType
  status       MigrationStatus     @default(RUNNING)
  totalRecords Int                 @default(0)
  successCount Int                 @default(0)
  failedCount  Int                 @default(0)
  skippedCount Int                 @default(0)
  metadata     Json?
  errorSummary String?
  startedAt    DateTime            @default(now())
  completedAt  DateTime?
  rolledBackAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  records      MigrationRecord[]

  @@index([entityType])
  @@index([status])
  @@index([startedAt])
  @@map("migration_runs")
}

model MigrationRecord {
  id           String                @id @default(uuid())
  runId        String
  entityType   MigrationEntityType
  legacyId     String
  newId        String?
  status       MigrationRecordStatus @default(SUCCESS)
  errorMessage String?
  rawData      Json?
  createdAt    DateTime              @default(now())
  run          MigrationRun          @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([entityType, legacyId])
  @@index([runId])
  @@index([entityType, legacyId])
  @@index([entityType, newId])
  @@index([status])
  @@map("migration_records")
}

model MigrationIdMap {
  id         String              @id @default(uuid())
  entityType MigrationEntityType
  legacyId   String
  newId      String
  createdAt  DateTime            @default(now())

  @@unique([entityType, legacyId])
  @@index([entityType, newId])
  @@map("migration_id_map")
}

model CatalogProduct {
  id                 String   @id @default(uuid())
  name               String
  slug               String?  @unique
  externalId         String?  @unique
  sku                String?
  serialNo           String?
  specifications     String?
  manufacturer       String
  description        String?
  mrp                Decimal? @db.Decimal(10, 2)
  gstPercent         Decimal? @db.Decimal(10, 2)
  isTaxIncluded      Boolean  @default(false)
  shippingCharges    Decimal  @default(0) @db.Decimal(10, 2)
  finalShippingPrice Decimal? @db.Decimal(10, 2)

  commissionPercent    Decimal? @db.Decimal(10, 2)
  fixedFee             Decimal? @db.Decimal(10, 2)
  commissionGstPercent Decimal? @db.Decimal(10, 2)
  fixedFeeGstPercent   Decimal? @db.Decimal(10, 2)
  shippingGstPercent   Decimal? @db.Decimal(10, 2)

  categoryId           String
  subCategoryId        String
  therapeuticClass     String?
  sideEffects          String?
  directionsForUse     String?
  safetyAdvice         String?
  packSize             String?
  storageAndHandling   String?
  options              Json?
  isActive             Boolean               @default(true)
  isYukiziChoice       Boolean               @default(false)
  productWaitlists     ProductWaitlist[]
  isBestSeller         Boolean               @default(false)
  isAd                 Boolean               @default(false)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  thirdCategoryId      String?
  images               CatalogProductImage[]
  catalogProductVideos CatalogProductVideo[]
  category             Category              @relation(fields: [categoryId], references: [id])
  subCategory          SubCategory           @relation(fields: [subCategoryId], references: [id])
  thirdCategory        ThirdCategory?        @relation(fields: [thirdCategoryId], references: [id])
  customOrders         CustomOrder[]
  marketingProducts    MarketingProduct[]
  productAnalytics     ProductAnalytics?
  productSearchIndex   ProductSearchIndex?
  productVariants      ProductVariant[]
  sellerOffers         SellerOffer[]
  reviews              Review[]

  @@index([name])
  @@index([manufacturer])
  @@index([externalId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("catalog_products")
}

model CatalogProductImage {
  id              String         @id @default(uuid())
  masterProductId String
  url             String
  createdAt       DateTime       @default(now())
  catalogProduct  CatalogProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)

  @@index([masterProductId])
  @@map("catalog_product_images")
}

model MarketingProduct {
  id               String         @id @default(uuid())
  catalogProductId String
  slot             MarketingSlot
  active           Boolean        @default(true)
  priority         Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sellerOfferId    String?
  catalogProduct   CatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)
  sellerOffer      SellerOffer?   @relation(fields: [sellerOfferId], references: [id])

  @@index([slot])
  @@index([active])
  @@map("marketing_products")
}

model ReferralCode {
  id             String         @id @default(uuid())
  code           String         @unique
  buyerId        String?
  isActive       Boolean        @default(true)
  usedCount      Int            @default(0)
  description    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  referredBuyers BuyerProfile[] @relation("ReferredBuyers")
  orders         Order[]
  buyer          BuyerProfile?  @relation("ReferrerCodes", fields: [buyerId], references: [id])

  @@map("referral_codes")
}

model CustomOrder {
  id               String          @id @default(uuid())
  buyerId          String
  catalogProductId String?
  message          String
  status           String          @default("PENDING")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  buyer            BuyerProfile    @relation(fields: [buyerId], references: [id])
  product          CatalogProduct? @relation(fields: [catalogProductId], references: [id])

  @@map("custom_orders")
}

model ProductRequest {
  id           String               @id @default(uuid())
  userId       String
  productName  String
  manufacturer String?
  description  String?
  status       ProductRequestStatus @default(PENDING)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("product_requests")
}

model ThirdCategory {
  id              String           @id @default(uuid())
  name            String
  slug            String
  subCategoryId   String
  createdAt       DateTime         @default(now())
  catalogProducts CatalogProduct[]
  subCategory     SubCategory      @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  @@unique([slug, subCategoryId])
  @@index([subCategoryId])
  @@map("third_categories")
}

model CatalogProductVideo {
  id               String         @id @default(uuid())
  catalogProductId String
  url              String
  createdAt        DateTime       @default(now())
  catalogProduct   CatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)

  @@index([catalogProductId])
  @@map("catalog_product_videos")
}

model ProductVariant {
  id               String         @id @default(uuid())
  catalogProductId String
  name             String
  sku              String?
  serialNo         String?
  options          Json
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  catalogProduct   CatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)
  sellerOffers     SellerOffer[]

  @@index([catalogProductId])
  @@index([sku])
  @@map("product_variants")
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model ChatbotJob {
  id        String   @id @default(uuid())
  jobId     String
  status    String
  history   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chatbot_jobs")
}

