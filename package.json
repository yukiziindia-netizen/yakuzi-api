    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.2",
    "@types/sanitize-html": "^2.16.1",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.0",
